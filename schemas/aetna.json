  "data_quality_rules": {
    "required_fields": ["SRC_MEMBER_ID"],
    "date_formats": ["MM/DD/YYYY", "YYYY-MM-DD", "MM-DD-YYYY"],
    "phone_validation": true,
    "zip_validation": true,
    "email_validation": false
  },
  "transformations": {
    "column_mappings": {},
    "value_mappings": {},
    "default_values": {}
  },

  "normalization": {
    "default_output_mode": "normalized-json",
    "tables": {
      "members": {
        "primary_key": "MEMBER_ID",
        "fallback_primary_key": "SRC_MEMBER_ID",
        "alternate_key": "MBI_NBR",
        "foreign_keys": { "providerTin": "PROVIDER_TIN" },
        "source_columns": [
          "MEMBER_ID", "SRC_MEMBER_ID", "MBI_NBR", "SRC_CUMB_ID",
          "MEMBER-NAME", "MEMBER_MI", "BIRTH_DT", "GENDER",
          "Language_cd", "SNP_IND",
          "ADDRESS_LINE_1_TXT", "ADDRESS_LINE_2_TXT", "CITY_NM",
          "STATE_POSTAL_CD", "ZIP_CD", "MEMBER_COUNTY", "MEM_PHONE", "Phone Number", "DNC",
          "LEGACY", "GROUP_NBR", "CMS_CNTRCT_NBR", "CMS_CNTRCT_NAME",
          "ORIG_COVG_EFF_DT", "CUSTOMER_NBR", "CUSTOMER_NM", "ONSHORE_OFF",
          "PBG_IND", "PBG_STATUS", "PBG_NBR", "PBG_NM", "VBC_IND", "VBC_NAME",
          "Latest_call_outcome", "latest_call_date", "insert_date",
          "PROVIDER_TIN"
        ]
      },
      "providers": {
        "primary_key": "PROVIDER_TIN",
        "source_columns": [
          "PROVIDER_TIN", "PROVIDER_ID", "EPDB_DW_PRVDR_ID", "PROVIDER_NAME",
          "TIN_NAME", "PROVIDER_ADDRESS", "PROVIDER_CITY", "PROVIDER_STATE",
          "PROVIDER_ZIP", "PROVIDER_COUNTY", "PROVIDER_PHONE_NBR", "PROVIDER_SPECIALTY"
        ]
      },
      "gaps": {
        "primary_key": "MEMBER_ID",
        "fallback_primary_key": "SRC_MEMBER_ID",
        "alternate_key": "MBI_NBR",
        "foreign_keys": { "providerTin": "PROVIDER_TIN" },
        "source_columns": [
          "MEMBER_ID", "MBI_NBR", "PROVIDER_TIN",
          "BCS_GAP", "CBP_GAP", "COL_GAP", "OMW_GAP", "OMW_FRACT_DT", "SPC_GAP"
        ]
      }
    }
  },

  "salesforce": {
    "_comment": "Configure SF_TARGET_OBJECT and SF_EXTERNAL_ID_FIELD in .env to activate Salesforce fan-out. Field mappings below translate cleaned column names to Salesforce API field names. Any column not listed here passes through with its original name.",
    "defaultObject": "Healthcare_Member__c",
    "externalIdField": "Member_ID__c",
    "tableMapping": {
      "aetnaMemberTbl": {
        "object": "Healthcare_Member__c",
        "externalIdField": "Member_ID__c",
        "fieldMappings": {
          "MEMBER_ID":     "Member_ID__c",
          "SRC_MEMBER_ID": "Source_Member_ID__c",
          "MBI_NBR":       "MBI_Number__c",
          "BIRTH_DT":      "Date_of_Birth__c",
          "GENDER":        "Gender__c",
          "MEMBER-NAME":   "Full_Name__c",
          "MEMBER_MI":     "Middle_Initial__c",
          "insert_date":   "Record_Date__c"
        }
      },
      "aetnaContractTbl": {
        "object": "Healthcare_Contract__c",
        "externalIdField": "CMS_Contract_Number__c",
        "fieldMappings": {
          "CMS_CNTRCT_NBR":  "CMS_Contract_Number__c",
          "CMS_CNTRCT_NAME": "Contract_Name__c",
          "GROUP_NBR":       "Group_Number__c",
          "ORIG_COVG_EFF_DT":"Original_Coverage_Date__c"
        }
      }
    }
